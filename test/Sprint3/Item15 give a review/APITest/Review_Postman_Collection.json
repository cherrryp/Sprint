    {
      "name": "0. Setup — Login Passenger",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const d = pm.response.json();",
              "if (d.token) pm.environment.set('passengerToken', d.token);",
              "if (d.data?.token) pm.environment.set('passengerToken', d.data.token);",
              "pm.test('Login success', () => pm.response.to.have.status(200));",
              "pm.test('Got token', () => pm.expect(pm.environment.get('passengerToken')).to.not.be.empty);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"username\": \"tester\",\n  \"password\": \"123456789\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
