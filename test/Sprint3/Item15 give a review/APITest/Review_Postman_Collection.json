    {
      "name": "1. POST /reviews — ✅ Passenger creates review",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', () => pm.response.to.have.status(201));",
              "const d = pm.response.json();",
              "pm.test('success = true', () => pm.expect(d.success).to.be.true);",
              "pm.test('Has review id', () => pm.expect(d.data.id).to.not.be.empty);",
              "pm.test('Rating matches', () => pm.expect(d.data.rating).to.eql(5));",
              "pm.environment.set('reviewId', d.data.id);",
              "pm.environment.set('driverIdFromReview', d.data.driverId);",
              "console.log('reviewId:', d.data.id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{passengerToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"bookingId\": \"{{bookingId}}\",\n  \"rating\": 5,\n  \"comment\": \"คนขับสุภาพมาก ตรงต่อเวลา แนะนำเลย 10/10\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/reviews",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "reviews"
          ]
        }
      },
      "response": []
    },
