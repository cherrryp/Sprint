{
  "info": {
    "_postman_id": "7cfbded9-822e-40b5-8992-e18ce135780c",
    "name": "Incident Report System API",
    "description": "API endpoints for Emergency/Incident Reporting (User & Admin)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "41516873"
  },
  "item": [
    {
      "name": "1. User Routes",
      "item": [
        {
          "name": "1.1 Create Incident Report",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{userToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"routeId\": \"cmmqg1bd700374oau1dvyoetb\",\n  \"category\": \"ACCIDENT\",\n  \"description\": \"เกิดอุบัติเหตุรถชนที่แยกไฟแดง มีผู้บาดเจ็บเล็กน้อย ต้องการความช่วยเหลือด่วน\",\n  \"location\": {\n    \"lat\": 15.270778929323832,\n    \"lng\": 102.47494426302912,\n    \"name\": \"ตำบล กระเบื้องใหญ่\",\n    \"address\": \"ตำบล กระเบื้องใหญ่ อำเภอพิมาย นครราชสีมา 30110 ประเทศไทย\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/incidents",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "incidents"
              ]
            }
          },
          "response": []
        },
        {
          "name": "1.2 Get My Incidents",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{userToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/incidents/my",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "incidents",
                "my"
              ]
            }
          },
          "response": []
        },
        {
          "name": "1.3 Upload Incident Evidence",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{userToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"evidences\": [\n    {\n      \"type\": \"IMAGE\",\n      \"url\": \"https://example.com/accident_scene.jpg\",\n      \"fileName\": \"accident_scene.jpg\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/incidents/{{incidentId}}/evidence",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "incidents",
                "{{incidentId}}",
                "evidence"
              ]
            }
          },
          "response": []
        },
        {
          "name": "1.4 Cancel Incident",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{userToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/incidents/{{incidentId}}/cancel",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "incidents",
                "{{incidentId}}",
                "cancel"
              ]
            }
          },
          "response": []
        },
        {
          "name": "1.5 Get Incident Details",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{userToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/incidents/{{incidentId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "incidents",
                "{{incidentId}}"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. Admin Routes",
      "item": [
        {
          "name": "2.1 Get All Incidents",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{adminToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/incidents/admin/all?status=PENDING",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "incidents",
                "admin",
                "all"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "PENDING"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "2.2 Assign Incident",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{adminToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/incidents/admin/{{incidentId}}/assign",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "incidents",
                "admin",
                "{{incidentId}}",
                "assign"
              ]
            }
          },
          "response": []
        },
        {
          "name": "2.3 Resolve Incident",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{adminToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"adminNotes\": \"ประสานงานกู้ภัยและนำรถลากเข้าช่วยเหลือเรียบร้อยแล้ว ผู้โดยสารปลอดภัย\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/incidents/admin/{{incidentId}}/resolve",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "incidents",
                "admin",
                "{{incidentId}}",
                "resolve"
              ]
            }
          },
          "response": []
        },
        {
          "name": "2.4 Reject Incident",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{adminToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"adminNotes\": \"ตรวจสอบแล้วไม่พบเหตุการณ์ดังกล่าว คาดว่าเป็นการแจ้งเหตุผิดพลาดหรือก่อกวน\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/incidents/admin/{{incidentId}}/reject",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "incidents",
                "admin",
                "{{incidentId}}",
                "reject"
              ]
            }
          },
          "response": []
        }
      ]
    }
  ],
