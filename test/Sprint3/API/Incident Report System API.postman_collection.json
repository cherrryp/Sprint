  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "userToken",
      "value": "your_user_jwt_token_here"
    },
    {
      "key": "adminToken",
      "value": "your_admin_jwt_token_here"
    },
    {
      "key": "incidentId",
      "value": "replace_with_incident_cuid_here"
    }
  ]
